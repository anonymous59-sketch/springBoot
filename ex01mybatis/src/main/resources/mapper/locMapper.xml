<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.location.mapper.LocationMapper">
	<select id="selectAll">
		SELECT *
		FROM   locations
	<where>
	<if test="city != null">
		AND city = #{city}
	</if>
	</where>
	</select>
	
	<select id ="selectOne">
		SELECT *
		FROM   locations
		WHERE  location_id = #{locid}
	</select>
	
	<insert id = "insert">
		INSERT INTO locations (location_id
							 , city)
		VALUES                (#{locationId}
							 , #{city})
	</insert>
	
	<delete id = "delete">
		DELETE FROM locations 
		WHERE       location_id = #{locid}
	</delete>
</mapper>